;; Symbol layer: Lafayette/Ergo‑L AltGr programmation layer for the masses!

(deflayer symbols
  _
       AG-1 AG-2 AG-3 AG-4 AG-5 XX   AG-6 AG-7 AG-8 AG-9 AG-0 AG-- AG-=
       @^   @<   @>   @$   @%        @@   @&   @*   @'   @`
  _    @{   @pl  @pr  @}   @=        @\   @+   @-   @/   @''
       @~   @[   @]   @_   @#   XX   @|   @?   @.   @:   @!
                 @msc          @pad            _
)

;; Note: this requires kanata 0.5+ to work properly.
;; kanata 0.4 does not release Shift soon enough for this layer to work.

;; NumPad
(deflayer numpad
  _
       _    _    _    _    _     _   _    _    _    _    _    _    _
       XX   home up   end  XX        @-   @7   @8   @9   @:
  _    XX   lft  down rght bspc      @/   @4   @5   @6   @0
       XX   XX   XX   XX   XX    _   @,   @1   @2   @3   @.
                 @std           spc            @sym
)

;; miscellanous keys
(deflayer miscpad
  _
       XX   nlk  slck caps XX   XX   XX   XX   XX   XX   XX   XX   XX
       XX   ins  brk  prnt XX        XX   f7   f8   f9   f12
  _    lmet lalt lsft lctl XX        menu f4   f5   f6   f10
       XX   XX   XX   XX   XX    _   XX   f1   f2   f3   f11
                 @std           XX             @std
)

(defalias
  std (layer-switch base)
  pad (tap-hold-press 0 $long_hold_timeout (layer-switch numpad) (layer-while-held numpad))
  msc (tap-hold-press 0 $long_hold_timeout (layer-switch miscpad) (layer-while-held miscpad))
)
;; vim: set ft=lisp